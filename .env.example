# Base URL of the streaming-distribution service
PUBLIC_DISTRIBUTION_URL=http://localhost:8082

# Public API key sent to streaming-distribution (baked into the client bundle).
# This is a PUBLIC_ value by design — there is no per-user auth.
PUBLIC_API_KEY=pk_dev

# Max duration (seconds) accepted for stories and reels
PUBLIC_STORY_MAX_SECONDS=60
PUBLIC_REEL_MAX_SECONDS=90
